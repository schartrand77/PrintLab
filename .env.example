APP_PORT=8080
# Optional multi-printer config (JSON array). If set, overrides single PRINTER_* block.
# Example:
# PRINTERS_JSON=[{"id":"x1c","name":"X1 Carbon","host":"192.168.1.101","serial":"SERIAL","access_code":"CODE"}]
PRINTERS_JSON=

PRINTER_NAME=
PRINTER_HOST=192.168.1.100
PRINTER_SERIAL=YOUR_PRINTER_SERIAL
PRINTER_ACCESS_CODE=YOUR_ACCESS_CODE
PRINTER_DEVICE_TYPE=unknown
PRINTER_LOCAL_MQTT=true
PRINTER_ENABLE_CAMERA=true
PRINTER_DISABLE_SSL_VERIFY=false

USER_LANGUAGE=en
FILE_CACHE_PATH=/data/cache
PRINT_CACHE_COUNT=1
TIMELAPSE_CACHE_COUNT=0
USAGE_HOURS=0
FORCE_IP=false

BAMBU_REGION=
BAMBU_EMAIL=
BAMBU_USERNAME=
BAMBU_AUTH_TOKEN=

# External integrations
MAKERWORKS_BASE_URL=
MAKERWORKS_API_KEY=
MAKERWORKS_BEARER_TOKEN=
MAKERWORKS_AUTH_HEADER=X-API-Key
MAKERWORKS_VERIFY_SSL=true

ORDERWORKS_BASE_URL=
ORDERWORKS_API_KEY=
ORDERWORKS_BEARER_TOKEN=
ORDERWORKS_AUTH_HEADER=X-API-Key
ORDERWORKS_VERIFY_SSL=true

STOCKWORKS_BASE_URL=
STOCKWORKS_API_KEY=
STOCKWORKS_BEARER_TOKEN=
STOCKWORKS_AUTH_HEADER=X-API-Key
STOCKWORKS_VERIFY_SSL=true
