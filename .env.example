APP_PORT=8080
# Optional multi-printer config (JSON array). If set, overrides single PRINTER_* block.
# Example:
# PRINTERS_JSON=[{"id":"x1c","name":"X1 Carbon","host":"192.168.1.101","serial":"SERIAL","access_code":"CODE"}]
PRINTERS_JSON=

PRINTER_NAME=
PRINTER_HOST=192.168.1.100
PRINTER_SERIAL=YOUR_PRINTER_SERIAL
PRINTER_ACCESS_CODE=YOUR_ACCESS_CODE
PRINTER_DEVICE_TYPE=unknown
PRINTER_LOCAL_MQTT=true
PRINTER_ENABLE_CAMERA=true
PRINTER_DISABLE_SSL_VERIFY=false

USER_LANGUAGE=en
FILE_CACHE_PATH=/data/cache
PRINT_CACHE_COUNT=1
TIMELAPSE_CACHE_COUNT=0
USAGE_HOURS=0
FORCE_IP=false

BAMBU_REGION=
BAMBU_EMAIL=
BAMBU_USERNAME=
BAMBU_AUTH_TOKEN=

# Auth defaults to required in container images. Set REQUIRE_AUTH=false only for local dev.
REQUIRE_AUTH=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_SECRET=
SESSION_TTL_SECONDS=1800
SESSION_COOKIE_SECURE=false

# External integrations
MAKERWORKS_BASE_URL=
MAKERWORKS_API_KEY=
MAKERWORKS_BEARER_TOKEN=
MAKERWORKS_AUTH_HEADER=X-API-Key
MAKERWORKS_VERIFY_SSL=true
MAKERWORKS_ALLOWED_PATHS=/health,/api/models
MAKERWORKS_ALLOWED_METHODS=
MAKERWORKS_LIBRARY_LIST_PATH=/api/models
MAKERWORKS_LIBRARY_DETAIL_PATH_TEMPLATE=/api/models/{model_id}
MAKERWORKS_LIBRARY_SEARCH_PARAM=q
MAKERWORKS_LIBRARY_PAGE_PARAM=page
MAKERWORKS_LIBRARY_PAGE_SIZE_PARAM=page_size
MAKERWORKS_LIBRARY_PAGE_SIZE=24
MAKERWORKS_LIBRARY_ITEMS_PATH=models|items|data.items|results
MAKERWORKS_LIBRARY_TOTAL_PATH=total|count|meta.total
MAKERWORKS_LIBRARY_ID_PATH=id|model_id|slug
MAKERWORKS_LIBRARY_NAME_PATH=title|name
MAKERWORKS_LIBRARY_SUMMARY_PATH=summary|subtitle|excerpt|tagline|material
MAKERWORKS_LIBRARY_DESCRIPTION_PATH=description|details|content
MAKERWORKS_LIBRARY_THUMBNAIL_PATH=coverImagePath|thumbnail_url|thumbnail|thumbnail.url|cover.url|image.url|preview_url
MAKERWORKS_LIBRARY_MODEL_URL_PATH=href|url|model_url|links.self|links.web
MAKERWORKS_LIBRARY_DOWNLOAD_URL_PATH=filePath|download_url|files.0.download_url|files.0.url|assets.0.download_url|assets.0.url|viewerFilePath
MAKERWORKS_LIBRARY_AUTHOR_PATH=creditName|author.name|author.display_name|author|owner.name|owner.display_name
MAKERWORKS_LIBRARY_TAGS_PATH=tags|categories|labels
MAKERWORKS_LIBRARY_FILES_PATH=files|assets
MAKERWORKS_LIBRARY_CREATED_AT_PATH=created_at|createdAt|published_at
MAKERWORKS_LIBRARY_UPDATED_AT_PATH=updated_at|updatedAt|modified_at
MAKERWORKS_ATTACH_GCODE_ENABLED=false
MAKERWORKS_ATTACH_GCODE_METHOD=POST
MAKERWORKS_ATTACH_GCODE_PATH_TEMPLATE=
MAKERWORKS_JOB_CALLBACK_ENABLED=false
MAKERWORKS_JOB_CALLBACK_METHOD=POST
MAKERWORKS_JOB_CALLBACK_PATH_TEMPLATE=

ORDERWORKS_BASE_URL=
ORDERWORKS_API_KEY=
ORDERWORKS_BEARER_TOKEN=
ORDERWORKS_AUTH_HEADER=X-API-Key
ORDERWORKS_VERIFY_SSL=true
ORDERWORKS_ALLOWED_PATHS=/health
ORDERWORKS_ALLOWED_METHODS=

STOCKWORKS_BASE_URL=
STOCKWORKS_API_KEY=
STOCKWORKS_BEARER_TOKEN=
STOCKWORKS_AUTH_HEADER=X-API-Key
STOCKWORKS_VERIFY_SSL=true
STOCKWORKS_ALLOWED_PATHS=/health
STOCKWORKS_ALLOWED_METHODS=
